{
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "YOUR_BOT_TOKEN",
      "dmPolicy": "allowlist",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID"],
      "groupPolicy": "allowlist",
      "groups": {
        "YOUR_GROUP_ID": {
          "requireMention": true
        }
      },
      "groupAllowFrom": ["YOUR_TELEGRAM_USER_ID"]
    }
  }
}
